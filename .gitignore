# ============================================================================
# .gitignore - Ignore arquivos sensíveis e desnecessários
# ============================================================================

# ============================================================================
# Ambiente Virtual
# ============================================================================
venv/
ENV/
env/
.venv
.ENV

# ============================================================================
# Credenciais e Variáveis de Ambiente
# ============================================================================
.env
.env.local
.env.*.local
service-account-key.json
service-account*.json

# ============================================================================
# Dados Sensíveis
# ============================================================================
data/
resultados.csv
*.csv.bak

# ============================================================================
# IDE e Editors
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.code-workspace

# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ============================================================================
# Pytest e Testes
# ============================================================================
.pytest_cache/
.coverage
.coverage.*
htmlcov/
*.cover
*.py,cover
.tox/
.hypothesis/

# ============================================================================
# mypy
# ============================================================================
.mypy_cache/
.dmypy.json
dmypy.json

# ============================================================================
# Logs
# ============================================================================
*.log
logs/

# ============================================================================
# OS
# ============================================================================
.DS_Store
Thumbs.db

# ============================================================================
# Dependências
# ============================================================================
node_modules/
package-lock.json
yarn.lock
